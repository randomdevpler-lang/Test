	-- =====================
	local SPEED = 0
	local enabled = false
	
	local keys = { W=false, A=false, S=false, D=false }
	
	-- =====================
	-- CHARACTER GETTERS
	-- =====================
	local function getChar()
		return player.Character or player.CharacterAdded:Wait()
	end
	
	local function getHumanoid()
		return getChar():WaitForChild("Humanoid")
	end
	
	local function getRoot()
		return getChar():WaitForChild("HumanoidRootPart")
	end
	
	-- =====================
	-- SPEED / ENABLE LOGIC
	-- =====================
	local function updateSpeedState()
		local text = speedBox.Text
	
		-- Disable if blank
		if text == "" then
			enabled = false
			SPEED = 0
			return
		end
	
		local num = tonumber(text)
		if num and num > 0 then
			SPEED = math.clamp(num, 0.1, 5)
			enabled = true
		else
			enabled = false
		end
	end
	
	-- Update when typing OR leaving box
	speedBox:GetPropertyChangedSignal("Text"):Connect(updateSpeedState)
	speedBox.FocusLost:Connect(updateSpeedState)
	
