local function NZHU_fake_script() -- Stealabrainrot.MainFrame.Drag 
	local script = Instance.new('LocalScript', Stealabrainrot.MainFrame)

	local UserInputService = game:GetService("UserInputService")
	local runService = (game:GetService("RunService"));
	
	local gui = script.Parent
	
	local dragging
	local dragInput
	local dragStart
	local startPos
	
	function Lerp(a, b, m)
		return a + (b - a) * m
	end;
	
	local lastMousePos
	local lastGoalPos
	local DRAG_SPEED = (8); -- // The speed of the UI darg.
	function Update(dt)
		if not (startPos) then return end;
		if not (dragging) and (lastGoalPos) then
			gui.Position = UDim2.new(startPos.X.Scale, Lerp(gui.Position.X.Offset, lastGoalPos.X.Offset, dt * DRAG_SPEED), startPos.Y.Scale, Lerp(gui.Position.Y.Offset, lastGoalPos.Y.Offset, dt * DRAG_SPEED))
			return 
		end;
	
		local delta = (lastMousePos - UserInputService:GetMouseLocation())
		local xGoal = (startPos.X.Offset - delta.X);
		local yGoal = (startPos.Y.Offset - delta.Y);
		lastGoalPos = UDim2.new(startPos.X.Scale, xGoal, startPos.Y.Scale, yGoal)
		gui.Position = UDim2.new(startPos.X.Scale, Lerp(gui.Position.X.Offset, xGoal, dt * DRAG_SPEED), startPos.Y.Scale, Lerp(gui.Position.Y.Offset, yGoal, dt * DRAG_SPEED))
	end;
	
	gui.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = gui.Position
			lastMousePos = UserInputService:GetMouseLocation()
	
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)
	
	gui.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)
	
	runService.Heartbeat:Connect(Update)
	
end
coroutine.wrap(NZHU_fake_script)()
local function WUVIP_fake_script() -- Stealabrainrot.GoPos.LocalScript 
	local script = Instance.new('LocalScript', Stealabrainrot.GoPos)

	-- SERVICES
	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	
	local player = Players.LocalPlayer
	local button = script.Parent
	
	-- SETTINGS
	local FLOOR_SIZE = Vector3.new(20, 1, 20)
	local MOVE_SPEED = 10 -- studs per second
	local Y_OFFSET = -4 -- distance under player
	
	-- STATE
	local enabled = false
	local floorPart = nil
	local connection = nil
	
	-- CREATE FLOOR
	local function createFloor()
		local char = player.Character
		if not char then return end
	
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if not hrp then return end
	
		floorPart = Instance.new("Part")
		floorPart.Size = FLOOR_SIZE
		floorPart.Anchored = true
		floorPart.CanCollide = true
		floorPart.Material = Enum.Material.SmoothPlastic
		floorPart.Color = Color3.fromRGB(120, 120, 120)
		floorPart.CFrame = CFrame.new(
			hrp.Position.X,
			hrp.Position.Y + Y_OFFSET,
			hrp.Position.Z
		)
		floorPart.Parent = workspace
	end
	
	-- START LIFT
	local function startLift()
		connection = RunService.Heartbeat:Connect(function(dt)
			if not floorPart then return end
	
			local char = player.Character
			local hrp = char and char:FindFirstChild("HumanoidRootPart")
			if not hrp then return end
	
			-- Follow player X/Z, move up on Y
			local newY = floorPart.Position.Y + (MOVE_SPEED * dt)
	
			floorPart.CFrame = CFrame.new(
				hrp.Position.X,
				newY,
				hrp.Position.Z
			)
		end)
	end
	
	-- STOP & CLEAN UP
	local function stopLift()
		if connection then
			connection:Disconnect()
			connection = nil
		end
	
		if floorPart then
			floorPart:Destroy()
			floorPart = nil
		end
	end
	
	-- BUTTON TOGGLE
	button.MouseButton1Click:Connect(function()
		enabled = not enabled
	
		if enabled then
			button.Text = "ON"
			createFloor()
			startLift()
		else
			button.Text = "OFF"
			stopLift()
		end
	end)
	
end
