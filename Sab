local function SZJCFY_fake_script() -- Stealabrainrot.iNFjUMP.LocalScript 
	local script = Instance.new('LocalScript', Stealabrainrot.iNFjUMP)

	local UIS = game:GetService("UserInputService")
	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	
	local player = Players.LocalPlayer
	local button = script.Parent
	
	local enabled = false
	local jumpConn, healthConn, posConn
	local lastCFrame
	
	button.Text = "Infinite Jump: OFF"
	
	local function getChar()
		return player.Character
	end
	
	local function getHum()
		local char = getChar()
		return char and char:FindFirstChildOfClass("Humanoid")
	end
	
	local function getRoot()
		local char = getChar()
		return char and char:FindFirstChild("HumanoidRootPart")
	end
	
	-- GODMODE
	local function enableGodMode()
		local hum = getHum()
		if not hum then return end
	
		hum.BreakJointsOnDeath = false
		hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
		hum.MaxHealth = math.huge
		hum.Health = hum.MaxHealth
	
		healthConn = hum.HealthChanged:Connect(function()
			if enabled then
				hum.Health = hum.MaxHealth
			end
		end)
	end
	
	local function disableGodMode()
		local hum = getHum()
		if not hum then return end
	
		if healthConn then
			healthConn:Disconnect()
			healthConn = nil
		end
	
		hum:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
		hum.BreakJointsOnDeath = true
		hum.MaxHealth = 100
		hum.Health = 100
	end
	
	-- INFINITE JUMP
	local function enableInfiniteJump()
		jumpConn = UIS.JumpRequest:Connect(function()
			if enabled then
				local hum = getHum()
				if hum then
					hum:ChangeState(Enum.HumanoidStateType.Jumping)
				end
			end
		end)
	end
	
	local function disableInfiniteJump()
		if jumpConn then
			jumpConn:Disconnect()
			jumpConn = nil
		end
	end
	
	-- ANTI TELEPORT
	local function enableAntiTP()
		posConn = RunService.Heartbeat:Connect(function()
			if not enabled then return end
			local root = getRoot()
			if not root then return end
	
			if not lastCFrame then
				lastCFrame = root.CFrame
			end
	
			-- If something tries to teleport you
			if (root.CFrame.Position - lastCFrame.Position).Magnitude > 10 then
				root.CFrame = lastCFrame
			else
				lastCFrame = root.CFrame
			end
		end)
	end
	
	local function disableAntiTP()
		if posConn then
			posConn:Disconnect()
			posConn = nil
		end
		lastCFrame = nil
	end
	
