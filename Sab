local function FHMX_fake_script() -- Stealabrainrot.Jump_2.LocalScript 
	local script = Instance.new('LocalScript', Stealabrainrot.Jump_2)

	-- SERVICES
	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	
	local player = Players.LocalPlayer
	local jumpBox = script.Parent
	
	-- =====================
	-- STATE
	-- =====================
	local ENABLED = false
	local JUMP_POWER = 50 -- default Roblox jump power
	
	-- =====================
	-- CHARACTER GETTERS
	-- =====================
	local function getChar()
		return player.Character or player.CharacterAdded:Wait()
	end
	
	local function getHumanoid()
		return getChar():WaitForChild("Humanoid")
	end
	
	-- =====================
	-- JUMP POWER LOGIC
	-- =====================
	local function updateJumpState()
		local text = jumpBox.Text
	
		-- Disable if blank
		if text == "" then
			ENABLED = false
			return
		end
	
		local num = tonumber(text)
		if num and num > 0 then
			JUMP_POWER = math.clamp(num, 10, 300)
			ENABLED = true
		else
			ENABLED = false
		end
	end
	
	jumpBox:GetPropertyChangedSignal("Text"):Connect(updateJumpState)
	jumpBox.FocusLost:Connect(updateJumpState)
	
	-- =====================
	-- FORCE JUMP POWER
	-- =====================
	RunService.Stepped:Connect(function()
		if not ENABLED then return end
	
		local humanoid = getHumanoid()
	
		-- Make sure JumpPower is used
		humanoid.UseJumpPower = true
		humanoid.JumpPower = JUMP_POWER
	end)
	
	-- =====================
	-- RESPAWN SAFE
	-- =====================
	player.CharacterAdded:Connect(function()
		updateJumpState()
	end)
	
end
coroutine.wrap(FHMX_fake_script)()
