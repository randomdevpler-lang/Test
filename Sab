	local button = script.Parent
	local camera = workspace.CurrentCamera
	
	-- STATE
	local flying = false
	local platform
	local connection
	local targetHeight = 0
	
	-- SETTINGS
	local PLATFORM_OFFSET = -3
	local LIFT_SPEED = 20
	
	-- CREATE PLATFORM
	local function createPlatform()
		local p = Instance.new("Part")
		p.Size = Vector3.new(6, 1, 6)
		p.Anchored = true
		p.CanCollide = true
		p.Transparency = 1
		p.Material = Enum.Material.Neon
		p.Color = Color3.fromRGB(0, 0, 0)
		p.Name = "FlyPlatform"
		p.Parent = workspace
		return p
	end
	
	-- START FLYING
	local function startFlying()
		flying = true
		button.Text = "ON"
	
		local char = player.Character or player.CharacterAdded:Wait()
		local hrp = char:WaitForChild("HumanoidRootPart")
		local humanoid = char:WaitForChild("Humanoid")
	
		platform = createPlatform()
	
		-- Lock starting height
		targetHeight = hrp.Position.Y + PLATFORM_OFFSET
	
		connection = RunService.RenderStepped:Connect(function(dt)
			if not flying then return end
	
			local moveDir = humanoid.MoveDirection
			local isMoving = moveDir.Magnitude > 0
	
			-- ONLY change height if moving
			if isMoving then
				local lookY = camera.CFrame.LookVector.Y
				targetHeight += lookY * LIFT_SPEED * dt
			end
	
			-- Platform ALWAYS stays under player X/Z
			platform.CFrame = CFrame.new(
				hrp.Position.X,
				targetHeight,
				hrp.Position.Z
			)
		end)
	end
	
